import sympy as sp
import pandas as pd

# ============================================================
# Test Developer
# ============================================================

tests = []

def symbolic_test(name, lhs, rhs=0):
    diff = sp.simplify(lhs - rhs)

    if isinstance(diff, sp.MatrixBase):
        passed = diff.equals(sp.zeros(*diff.shape))
    else:
        passed = bool(sp.simplify(diff) == 0)

    tests.append({
        "section": "action_variation",
        "test": name,
        "passed": passed,
        "detail": str(diff)
    })

    return passed, diff


def info_row(name, value):
    tests.append({
        "section": "info",
        "test": name,
        "passed": True,
        "detail": str(value)
    })


# ============================================================
# Symbols and functions
# ============================================================

t, x = sp.symbols("t x", real=True)

Psi = sp.Function("Psi")(t, x)
w = sp.symbols("w", real=True)

a2, a4, ZH, ZA = sp.symbols("a2 a4 Z_H Z_A", positive=False)
k2, F = sp.symbols("k2 F")
J = sp.symbols("J")

# For Higgs stability assumptions, use separate positive symbols
A2neg, A4pos, ZHpos = sp.symbols("A2neg A4pos ZHpos", positive=True)

# ============================================================
# 1. Scalar Euler-Lagrange equation
# L = 1/2(Psi_t^2 - Psi_x^2) - V(Psi)
# Expect: Psi_tt - Psi_xx + dV/dPsi = 0
# ============================================================

Psi_t = sp.diff(Psi, t)
Psi_x = sp.diff(Psi, x)

m2, lam = sp.symbols("m2 lambda")
V_poly = sp.Rational(1, 2)*m2*Psi**2 + sp.Rational(1, 4)*lam*Psi**4

L_scalar = sp.Rational(1, 2)*Psi_t**2 - sp.Rational(1, 2)*Psi_x**2 - V_poly

dL_dPsi = sp.diff(L_scalar, Psi)
dL_dPsit = sp.diff(L_scalar, Psi_t)
dL_dPsix = sp.diff(L_scalar, Psi_x)

EL_scalar = sp.simplify(
    sp.diff(dL_dPsit, t)
    + sp.diff(dL_dPsix, x)
    - dL_dPsi
)

expected_EL_scalar = (
    sp.diff(Psi, t, 2)
    - sp.diff(Psi, x, 2)
    + m2*Psi
    + lam*Psi**3
)

symbolic_test(
    "Scalar Euler-Lagrange gives wave equation plus potential derivative",
    EL_scalar,
    expected_EL_scalar
)

# ============================================================
# 2. Higgs / MR displacement potential
# V(w)=1/2 a2 w^2 + 1/4 a4 w^4
# Vacuum: dV/dw=0 -> w0^2=-a2/a4 for nonzero vacuum
# Curvature: V''(w0)=-2a2
# ============================================================

Vw = sp.Rational(1, 2)*a2*w**2 + sp.Rational(1, 4)*a4*w**4

dVdw = sp.diff(Vw, w)
d2Vdw2 = sp.diff(Vw, w, 2)

w0sq = -a2/a4

# Correct nonzero vacuum condition:
# dV/dw = w(a2 + a4 w^2)
# For w != 0, require a2 + a4 w0^2 = 0.
vacuum_expr = sp.simplify(a2 + a4*w0sq)

symbolic_test(
    "Higgs nonzero vacuum condition from dV/dw=0",
    vacuum_expr,
    0
)

symbolic_test(
    "Higgs curvature at displaced vacuum",
    d2Vdw2.subs(w**2, w0sq),
    -2*a2
)

# MR physical closures
# Convention:
#   V(H)= -mu^2 |H|^2 + lambda |H|^4
#   mH^2 = 2 lambda v^2
#   v^2 = -ZH*a2/a4
#   mH^2 = -2a2/ZH
# Therefore:
#   lambda = a4/ZH^2

v2_MR = -ZH*a2/a4
mH2_MR = -2*a2/ZH
lambda_MR = a4/ZH**2

symbolic_test(
    "MR Higgs closure mH^2 = 2 lambda v^2",
    2*lambda_MR*v2_MR,
    mH2_MR
)

# ============================================================
# 3. Higgs stability under assumptions
# Let a2=-A2neg, a4=A4pos, ZH=ZHpos
# ============================================================

w0sq_stable = sp.simplify(w0sq.subs({a2: -A2neg, a4: A4pos}))
mH2_stable = sp.simplify(mH2_MR.subs({a2: -A2neg, ZH: ZHpos}))

info_row("Stable Higgs vacuum w0^2 under a2<0,a4>0", w0sq_stable)
info_row("Stable Higgs mass mH^2 under a2<0,ZH>0", mH2_stable)

symbolic_test(
    "Stable Higgs vacuum expression positive form",
    w0sq_stable,
    A2neg/A4pos
)

symbolic_test(
    "Stable Higgs mass expression positive form",
    mH2_stable,
    2*A2neg/ZHpos
)

# ============================================================
# 4. Gauge variation check in toy form
# ============================================================

q = sp.Function("q")(t)
qdot = sp.diff(q, t)

L_gauge_toy = sp.Rational(1, 2)*ZA*qdot**2 + J*q

EL_q = sp.simplify(
    sp.diff(sp.diff(L_gauge_toy, qdot), t)
    - sp.diff(L_gauge_toy, q)
)

expected_EL_q = ZA*sp.diff(q, t, 2) - J

symbolic_test(
    "Gauge toy variation gives Z_A qddot = J",
    EL_q,
    expected_EL_q
)

# ============================================================
# 5. Field-strength antisymmetry
# ============================================================

A0 = sp.Function("A0")(t, x)
A1 = sp.Function("A1")(t, x)

coords = [t, x]
A = [A0, A1]

Fmat = sp.Matrix([
    [sp.diff(A[j], coords[i]) - sp.diff(A[i], coords[j]) for j in range(2)]
    for i in range(2)
])

symbolic_test(
    "Field strength antisymmetry F + F^T = 0",
    Fmat + Fmat.T,
    sp.zeros(2)
)

# ============================================================
# 6. Propagator denominator from quadratic action
# ============================================================

K = k2 - F
D = 1/K

symbolic_test(
    "Propagator is inverse of quadratic kernel",
    sp.simplify(K*D),
    1
)

symbolic_test(
    "GR propagator recovered when F=0",
    D.subs(F, 0),
    1/k2
)

# ============================================================
# 7. Spectral positivity / unitarity form
# ============================================================

g_n = sp.symbols("g_n", real=True)
spectral_weight = g_n**2

info_row("Spectral weight form", spectral_weight)

symbolic_test(
    "Spectral weight is square form",
    spectral_weight,
    g_n**2
)

# ============================================================
# 8. Compact correction positivity identities
# ============================================================

C_A_expr = (1 + 1/(5*sp.pi**4))**sp.Rational(1, 4)
C_EW_expr = (1 + 1/(2*sp.pi**2))**sp.Rational(3, 4)

info_row("C_A compact correction", C_A_expr)
info_row("C_EW compact correction", C_EW_expr)

symbolic_test(
    "C_A fourth power identity",
    C_A_expr**4,
    1 + 1/(5*sp.pi**4)
)

symbolic_test(
    "C_EW four-thirds power identity",
    C_EW_expr**sp.Rational(4, 3),
    1 + 1/(2*sp.pi**2)
)

# ============================================================
# Output
# ============================================================

df = pd.DataFrame(tests)

print("================================================")
print("Dynamic Gravity — ACTION VARIATION TESTER v3.1")
print("================================================")
print(df.to_string(index=False))
print("================================================")

print("\nSummary:")
print(df["passed"].value_counts())

failed = df[df["passed"] == False]

if len(failed):
    print("\nFAILED TESTS:")
    print(failed.to_string(index=False))
else:
    print("\nAll action-variation tests passed.")

df.to_csv("master_relativity_action_variation_tester_v3_1_results.csv", index=False)

