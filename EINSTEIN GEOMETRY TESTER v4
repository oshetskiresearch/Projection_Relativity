tests = []

def symbolic_test(name, lhs, rhs=0, section="curvature"):
    diff = sp.simplify(lhs - rhs)

    if isinstance(diff, sp.MatrixBase):
        passed = diff.equals(sp.zeros(*diff.shape))
    else:
        passed = bool(sp.simplify(diff) == 0)

    tests.append({
        "section": section,
        "test": name,
        "passed": passed,
        "detail": str(diff)
    })

    return passed, diff


def info_row(name, value, section="info"):
    tests.append({
        "section": section,
        "test": name,
        "passed": True,
        "detail": str(value)
    })


def matrix_simplify(M):
    return M.applyfunc(lambda x: sp.simplify(sp.factor(x)))


