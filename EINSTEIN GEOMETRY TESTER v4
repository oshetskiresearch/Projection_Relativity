# ============================================================
# Metric construction
# ============================================================

def kerr_metric():
    Sigma = r**2 + a**2*sp.cos(th)**2
    Delta = r**2 - 2*G*M*r + a**2

    g_tt = -(1 - 2*G*M*r/Sigma)
    g_tph = -2*G*M*a*r*sp.sin(th)**2/Sigma
    g_rr = Sigma/Delta
    g_thth = Sigma
    g_phph = (
        r**2 + a**2 + 2*G*M*a**2*r*sp.sin(th)**2/Sigma
    )*sp.sin(th)**2

    g = sp.Matrix([
        [g_tt,  0,     0,      g_tph],
        [0,     g_rr,  0,      0],
        [0,     0,     g_thth, 0],
        [g_tph, 0,     0,      g_phph]
    ])

    return g, Sigma, Delta


def schwarzschild_metric():
    f = 1 - 2*G*M/r

    g = sp.Matrix([
        [-f, 0,   0,                  0],
        [0,  1/f, 0,                  0],
        [0,  0,   r**2,               0],
        [0,  0,   0,                  r**2*sp.sin(th)**2]
    ])

    return g


g_kerr, Sigma, Delta = kerr_metric()
g_schw = schwarzschild_metric()

# ============================================================
# Tensor functions
# ============================================================

def christoffel_symbols(metric, coordinates):
    n = len(coordinates)
    inv_metric = sp.simplify(metric.inv())

    Gamma = [[[
        sp.simplify(
            sp.Rational(1, 2) * sum(
                inv_metric[i, l] * (
                    sp.diff(metric[l, j], coordinates[k])
                    + sp.diff(metric[l, k], coordinates[j])
                    - sp.diff(metric[j, k], coordinates[l])
                )
                for l in range(n)
            )
        )
        for k in range(n)]
        for j in range(n)]
        for i in range(n)]

    return Gamma


def ricci_tensor(metric, coordinates):
    n = len(coordinates)
    Gamma = christoffel_symbols(metric, coordinates)

    R = [[0 for _ in range(n)] for _ in range(n)]

    for i in range(n):
        for j in range(n):
            expr = 0

            for k in range(n):
                expr += sp.diff(Gamma[k][i][j], coordinates[k])
                expr -= sp.diff(Gamma[k][i][k], coordinates[j])

                for l in range(n):
                    expr += Gamma[k][i][j]*Gamma[l][k][l]
                    expr -= Gamma[l][i][k]*Gamma[k][j][l]

            R[i][j] = sp.simplify(sp.factor(expr))

    return sp.Matrix(R)


def ricci_scalar(metric, coordinates):
    inv_metric = sp.simplify(metric.inv())
    Ricci = ricci_tensor(metric, coordinates)

    Rscalar = 0
    for i in range(len(coordinates)):
        for j in range(len(coordinates)):
            Rscalar += inv_metric[i, j]*Ricci[i, j]

    return sp.simplify(sp.factor(Rscalar))


def einstein_tensor(metric, coordinates):
    Ricci = ricci_tensor(metric, coordinates)
    Rscalar = ricci_scalar(metric, coordinates)

    return matrix_simplify(
        Ricci - sp.Rational(1, 2)*metric*Rscalar
    )


