def cutoff_ratio(mu_max, k2=1e-5):
    m = np.linspace(0.1, mu_max, 3000)
    shape = m**2 * np.exp(-m**2 / 9.0)
    shape = shape / np.trapezoid(shape, m)
    rho_cut = g_P**2 * shape
    def F_cut(x):
        return np.trapezoid(rho_cut / (x - m**2 + 1j*eps), m)
    return abs((F_cut(k2) - F_cut(0.0)) / k2)

