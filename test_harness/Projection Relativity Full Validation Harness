    return Omega_L0*A_theta*R_theta(z) / E2(z)

def suppression_window(z):
    return 1.0 / (1.0 + (z/z_s)**q_growth)

def Omega_m_z(z):
    return Omega_m0*(1+z)**3/E2(z)

