def kerr_220_fit(a):
    f1, f2, f3 = 1.5251, -1.1568, 0.1292
    q1, q2, q3 = 0.7000, 1.4187, -0.4990
    omega_R = f1 + f2*(1-a)**f3
    Q = q1 + q2*(1-a)**q3
    omega_I = -omega_R/(2*Q)
    return omega_R, omega_I, Q

